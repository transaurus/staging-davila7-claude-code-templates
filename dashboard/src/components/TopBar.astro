---
import ThemeToggle from './ThemeToggle.tsx';
---

<header class="sticky top-0 z-20 bg-[var(--color-surface-0)]/95 backdrop-blur-xl border-b border-[var(--color-border)] shadow-sm transition-all duration-200">
  <div class="flex items-center justify-between px-6 h-16">
    <!-- Mobile menu button -->
    <button
      class="md:hidden p-2.5 rounded-lg hover:bg-[var(--color-surface-2)] text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-all duration-150 active:scale-95 flex items-center justify-center border border-transparent hover:border-[var(--color-border)]"
      onclick="toggleSidebar()"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Search trigger -->
    <button
      id="searchTrigger"
      class="flex items-center gap-3 px-4 py-2.5 border border-[var(--color-border)] rounded-xl text-[13px] text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] hover:border-[var(--color-border-hover)] hover:bg-[var(--color-surface-1)] hover:shadow-lg transition-all duration-150 w-full max-w-md group"
    >
      <svg class="w-4 h-4 shrink-0 transition-transform duration-150 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <span class="font-medium">Search components...</span>
      <kbd class="hidden sm:inline-flex ml-auto items-center gap-1 px-2.5 py-1 text-[10px] font-mono font-bold border border-[var(--color-border)] rounded-md bg-[var(--color-surface-2)] text-[var(--color-text-tertiary)] shadow-sm group-hover:shadow-md transition-all group-hover:border-[var(--color-border-hover)]">
        <span class="text-[11px]">⌘</span>K
      </kbd>
    </button>

    <!-- Right actions -->
    <div class="flex items-center gap-3 ml-4">
      <a 
        href="https://github.com/davila7/claude-code-templates" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="flex items-center gap-2.5 px-4 py-2.5 rounded-lg text-[13px] font-semibold text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-2)] hover:shadow-sm border border-transparent hover:border-[var(--color-border)] transition-all duration-150 group"
        aria-label="View on GitHub"
      >
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110 group-hover:rotate-12" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
      <ThemeToggle client:load />
      <div id="cart-button-mount"></div>
    </div>
  </div>
</header>
